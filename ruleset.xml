<?xml version="1.0"?>
<ruleset name="PackageName">
    <description>PHP CodeSniffer ruleset for Package Name.</description>

    <file>src</file>
    <file>tests</file>

    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>
    <arg name="colors"/>

    <!-- Show progress of the run and show sniff codes in all reports -->
    <arg value="ps"/>

    <rule ref="PSR12"/>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>
</ruleset>
